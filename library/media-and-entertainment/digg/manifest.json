{
  "manifest_version": "0.3",
  "name": "digg-pp-mcp",
  "display_name": "Digg AI",
  "version": "4.0.6",
  "description": "Read-only CLI for Digg AI — the 1,000 AI accounts on X and the story clusters they surface.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/digg-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/digg-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
